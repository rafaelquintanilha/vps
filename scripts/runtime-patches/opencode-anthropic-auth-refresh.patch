+    if (!json?.access_token || !json?.expires_in) {
+      logRefreshEvent("refresh_invalid_payload", {
+        status: response.status,
+        bodyPreview: sanitizeRefreshLogValue(raw),
+      });
+      throw new Error("Token refresh failed: invalid payload");
+    }
+
+    const nextRefresh = json.refresh_token || current.refresh || auth.refresh;
+    const next = {
+      type: "oauth",
+      refresh: nextRefresh,
+      access: json.access_token,
+      expires: Date.now() + json.expires_in * 1000,
+    };
+
+    await client.auth.set({
+      path: {
+        id: "anthropic",
+      },
+      body: next,
+    });
+
