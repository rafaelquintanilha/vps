+function cloneOAuthAuth(source) {
+  if (!source || source.type !== "oauth") {
+    return null;
+  }
+
+  return {
+    type: "oauth",
+    access: source.access || "",
+    refresh: source.refresh || "",
+    expires: typeof source.expires === "number" ? source.expires : 0,
+  };
