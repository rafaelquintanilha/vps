+const REFRESH_LOCK_DIR = "/tmp/opencode-anthropic-auth-refresh.lock";
+const REFRESH_LOCK_WAIT_MS = 250;
+const REFRESH_LOCK_TIMEOUT_MS = 15000;
+const REFRESH_LOCK_STALE_MS = 30000;
+const REFRESH_LOG_PREFIX = "[roboi-anthropic-auth]";
+
+function sleep(ms) {
+  return new Promise((resolve) => setTimeout(resolve, ms));
+}
+
+function applyAuthState(target, source) {
+  target.access = source.access;
+  target.refresh = source.refresh;
+  target.expires = source.expires;
+}
+
+function sanitizeRefreshLogValue(value) {
+  if (!value) return null;
+  return String(value)
+    .replace(/sk-ant-[A-Za-z0-9_-]+/g, "[redacted]")
+    .replace(/[A-Za-z0-9_-]{80,}/g, "[redacted]")
+    .slice(0, 240);
+}
+
+function logRefreshEvent(event, details = {}) {
+  try {
+    console.info(
+      `${REFRESH_LOG_PREFIX} ${JSON.stringify({
+        event,
+        at: new Date().toISOString(),
+        ...details,
+      })}`
+    );
+  } catch {}
+}
+
+async function withRefreshLock(task) {
+  const deadline = Date.now() + REFRESH_LOCK_TIMEOUT_MS;
+
+  while (true) {
+    try {
+      await mkdir(REFRESH_LOCK_DIR);
+      break;
+    } catch (error) {
+      if (error && error.code === "EEXIST") {
+        try {
+          const info = await stat(REFRESH_LOCK_DIR);
+          if (Date.now() - info.mtimeMs > REFRESH_LOCK_STALE_MS) {
+            await rm(REFRESH_LOCK_DIR, { recursive: true, force: true });
+            continue;
+          }
+        } catch {}
+
+        if (Date.now() >= deadline) {
+          throw new Error("Timed out waiting for Anthropic OAuth refresh lock");
+        }
+
+        await sleep(REFRESH_LOCK_WAIT_MS);
+        continue;
+      }
+
+      throw error;
+    }
+  }
+
+  try {
+    return await task();
+  } finally {
+    await rm(REFRESH_LOCK_DIR, { recursive: true, force: true });
+  }
+}
+
+async function refreshAccessToken(getAuth, client, auth) {
+  // Roboi runtime patch: serialize Anthropic OAuth refresh, preserve the refresh token, and keep in-memory auth state in sync.
+  await withRefreshLock(async () => {
+    const current = await getAuth();
+    if (current.type !== "oauth") return;
+
+    if (current.access && current.expires > Date.now()) {
+      logRefreshEvent("refresh_reused_existing", {
+        expiresInMs: current.expires - Date.now(),
+      });
+      applyAuthState(auth, current);
+      return;
+    }
+
+    const refreshToken = current.refresh || auth.refresh;
+    if (!refreshToken) {
+      logRefreshEvent("refresh_missing_token", {
+        hasCurrentRefresh: Boolean(current.refresh),
+        hasAuthRefresh: Boolean(auth.refresh),
+      });
+      throw new Error("Token refresh failed: missing refresh token");
+    }
+
+    logRefreshEvent("refresh_started", {
+      hasCurrentAccess: Boolean(current.access),
+      hasCurrentRefresh: Boolean(current.refresh),
+      hasAuthRefresh: Boolean(auth.refresh),
+      expiredByMs: typeof current.expires === "number" ? Date.now() - current.expires : null,
+    });
+
+    const response = await fetch("https://console.anthropic.com/v1/oauth/token", {
+      method: "POST",
+      headers: {
+        "Content-Type": "application/json",
+      },
+      body: JSON.stringify({
