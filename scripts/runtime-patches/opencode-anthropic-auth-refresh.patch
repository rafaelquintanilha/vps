+      expiresInSec: json.expires_in,
+      returnedRefreshToken: Boolean(json.refresh_token),
+      preservedRefreshToken: !json.refresh_token && Boolean(nextRefresh),
+    });
+
+    applyAuthState(auth, next);
+  });
+}
 
